              "mode": "raw",
              "raw": "{\n  \"language\": \"javascript\",\n  \"code\": \"const [a,b]=require('fs').readFileSync(0,'utf8').split(' ').map(Number);console.log(a+b);\",\n  \"input\": \"3 4\"\n}"
            }
          }
        },
        {
