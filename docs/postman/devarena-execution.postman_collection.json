              "mode": "raw",
              "raw": "{\n  \"language\": \"java\",\n  \"code\": \"import java.util.*;public class Main{public static void main(String[] a){Scanner s=new Scanner(System.in);System.out.println(s.nextLong()+s.nextLong());}}\",\n  \"input\": \"5 6\"\n}"
