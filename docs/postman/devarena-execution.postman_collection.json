            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{execBaseUrl}}/execute",
              "host": [
                "{{execBaseUrl}}"
              ],
              "path": [
                "execute"
              ]
            },
            "description": "Floods stdout past the output ceiling \u2192 OUTPUT_LIMIT_EXCEEDED (truncated).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"python\",\n  \"code\": \"print('a'*10_000_000)\"\n}"
            }
          }
        }
      ]
    },
