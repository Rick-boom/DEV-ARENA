              "host": [
                "{{execBaseUrl}}"
              ],
              "path": [
                "execute"
              ]
            },
            "description": "Allocates past the cap; OOM kill \u2192 MEMORY_LIMIT_EXCEEDED.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"python\",\n  \"code\": \"x=' '*(10**9)\",\n  \"memoryLimitMb\": 32\n}"
