# ── Backend runtime ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Data stores ─────────────────────────────────────────────────
# Matches docker-compose service names when run in containers.
DATABASE_URL=postgresql://devarena:devarena@localhost:5432/devarena?schema=public
REDIS_URL=redis://localhost:6379

# ── Security ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=replace-me-with-a-different-random-value

# ── CORS ────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
