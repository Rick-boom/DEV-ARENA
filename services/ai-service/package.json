{
  "name": "@devarena/ai-service",
  "version": "0.1.0",
  "private": true,
  "description": "Internal HTTP service that will wrap the Gemini API (hints, code review). Foundation: server + health only.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "echo \"no tests yet\" && exit 0"
  },
  "dependencies": {
    "@devarena/shared-types": "workspace:*",
    "@devarena/shared-utils": "workspace:*",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@devarena/eslint-config": "workspace:*",
    "@devarena/ts-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
