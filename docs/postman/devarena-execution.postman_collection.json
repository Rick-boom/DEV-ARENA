{
  "info": {
    "name": "DevArena \u2014 Execution Engine API",
    "description": "Remote code execution over a BullMQ queue. Set {{execBaseUrl}} (e.g. http://localhost:5001). Each request runs in a single-use, network-isolated, resource-capped Docker container.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "execBaseUrl",
      "value": "http://localhost:5001"
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "Health + queue depth",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{execBaseUrl}}/health",
              "host": [
                "{{execBaseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Liveness probe; returns live BullMQ job counts."
          }
        }
      ]
    },
    {
      "name": "Execute \u2014 verdicts",
      "item": [
        {
          "name": "Python \u2014 ACCEPTED",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{execBaseUrl}}/execute",
              "host": [
                "{{execBaseUrl}}"
              ],
              "path": [
                "execute"
              ]
            },
            "description": "Reads two ints from stdin, prints their sum. Expect status ACCEPTED, stdout \"9\".",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"python\",\n  \"code\": \"print(sum(map(int, input().split())))\",\n  \"input\": \"2 7\"\n}"
            }
          }
        },
        {
          "name": "JavaScript \u2014 ACCEPTED",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
