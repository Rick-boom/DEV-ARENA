{
  "info": {
    "name": "DevArena \u2014 Online Judge",
    "description": "Submission + judging API. Set {{baseUrl}} (e.g. http://localhost:4000/api/v1), {{accessToken}} (JWT), {{problemId}}, {{submissionId}}.\\n\\nPOST /submission returns 202 immediately \u2014 judging is async on the worker. Poll GET /submission/:id or subscribe to submission.verdict events.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api/v1"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "problemId",
      "value": "11111111-1111-4111-8111-111111111111"
    },
    {
      "key": "submissionId",
      "value": ""
    },
    {
      "key": "battleId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Submit",
      "item": [
        {
          "name": "Create submission (practice)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/submission",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "submission"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "202 Accepted \u2192 { submissionId }. Judged asynchronously at PRACTICE priority.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"problemId\": \"{{problemId}}\",\n  \"language\": \"JAVASCRIPT\",\n  \"code\": \"const lines=require('fs').readFileSync(0,'utf8').split('\\\\n');\\nconsole.log(Number(lines[0])*2);\"\n}"
            }
          }
        },
        {
          "name": "Create submission (battle \u2014 high priority)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/submission",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "submission"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "Battle submissions are judged ahead of practice, stop on first failure, and use partial scoring.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"problemId\": \"{{problemId}}\",\n  \"language\": \"JAVASCRIPT\",\n  \"code\": \"const lines=require('fs').readFileSync(0,'utf8').split('\\\\n');\\nconsole.log(Number(lines[0])*2);\",\n  \"battleId\": \"{{battleId}}\"\n}"
            }
          }
        },
        {
          "name": "Duplicate re-submit -> 409",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/submission",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "submission"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "Identical code within the dedupe window returns DUPLICATE_SUBMISSION.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"problemId\": \"{{problemId}}\",\n  \"language\": \"JAVASCRIPT\",\n  \"code\": \"const lines=require('fs').readFileSync(0,'utf8').split('\\\\n');\\nconsole.log(Number(lines[0])*2);\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Read",
      "item": [
        {
          "name": "Get submission by id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/submission/{{submissionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "submission",
                "{{submissionId}}"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "Status + metadata. Status walks PENDING \u2192 QUEUED \u2192 RUNNING \u2192 final verdict."
          }
        },
        {
          "name": "Per-test-case result breakdown",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/submission/result?submissionId={{submissionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "submission",
                "result"
              ],
              "query": [
                {
                  "key": "submissionId",
                  "value": "{{submissionId}}",
                  "description": ""
                }
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "Hidden cases expose only pass/fail + timing \u2014 never input, expected output, or stderr."
          }
        },
        {
          "name": "My submission history",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/submission/history?limit=20&offset=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "submission",
                "history"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20",
                  "description": ""
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": ""
                }
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "Paginated recent submissions for the caller."
          }
        }
      ]
    },
    {
      "name": "Error cases",
      "item": [
        {
          "name": "Empty code -> 400",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/submission",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "submission"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "Zod validation rejects empty code.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"problemId\": \"{{problemId}}\",\n  \"language\": \"JAVASCRIPT\",\n  \"code\": \"\"\n}"
            }
          }
        },
        {
          "name": "Unknown problem -> 422",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/submission",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "submission"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "PROBLEM_NOT_JUDGEABLE.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"problemId\": \"00000000-0000-4000-8000-000000000000\",\n  \"language\": \"JAVASCRIPT\",\n  \"code\": \"const lines=require('fs').readFileSync(0,'utf8').split('\\\\n');\\nconsole.log(Number(lines[0])*2);\"\n}"
            }
          }
        },
        {
          "name": "Unknown submission -> 404",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/submission/00000000-0000-4000-8000-000000000000",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "submission",
                "00000000-0000-4000-8000-000000000000"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "SUBMISSION_NOT_FOUND."
          }
        },
        {
          "name": "Rate limit -> 429",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/submission",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "submission"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "RATE_LIMIT_EXCEEDED after >20 submissions/minute.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"problemId\": \"{{problemId}}\",\n  \"language\": \"JAVASCRIPT\",\n  \"code\": \"// spam\"\n}"
            }
          }
        }
      ]
    }
  ]
}