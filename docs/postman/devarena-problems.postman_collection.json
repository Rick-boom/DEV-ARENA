              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "problems",
                "{{problemId}}"
              ]
            },
            "description": "409 VERSION_CONFLICT if expectedVersion is stale.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expectedVersion\": 1,\n  \"title\": \"Two Sum (revised)\"\n}"
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
