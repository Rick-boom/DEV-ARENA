            "url": {
              "raw": "{{execBaseUrl}}/execute",
              "host": [
                "{{execBaseUrl}}"
              ],
              "path": [
                "execute"
              ]
            },
            "description": "Infinite loop; the watchdog force-kills the container. Expect TIME_LIMIT_EXCEEDED.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"language\": \"python\",\n  \"code\": \"while True: pass\",\n  \"timeLimitMs\": 1000\n}"
            }
          }
