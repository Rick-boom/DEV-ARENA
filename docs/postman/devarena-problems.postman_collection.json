{
  "info": {
    "name": "DevArena \u2014 Problem Management API",
    "description": "Complete request set for the Problem Service. Set {{baseUrl}} (e.g. http://localhost:4000/api/v1) and {{accessToken}} (JWT from the auth module) in the collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api/v1"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "problemId",
      "value": "two-sum"
    }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "List problems",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/problems?page=1&pageSize=20&sortBy=newest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "problems"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "20"
                },
                {
                  "key": "sortBy",
                  "value": "newest"
                }
              ]
            },
            "description": "Paginated list. Guests welcome; send the token to get isSolved/isBookmarked flags."
          }
        },
        {
          "name": "List \u2014 filtered",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/problems?difficulty=EASY&tags=array,hash-table&companies=google&sortBy=acceptance",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "problems"
              ],
              "query": [
                {
                  "key": "difficulty",
                  "value": "EASY"
                },
                {
                  "key": "tags",
                  "value": "array,hash-table"
                },
                {
                  "key": "companies",
                  "value": "google"
                },
                {
                  "key": "sortBy",
                  "value": "acceptance"
                }
              ]
            },
            "description": ""
          }
        },
        {
          "name": "Search by keyword",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/problems/search?q=two sum",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "problems",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "two sum"
                }
              ]
            },
            "description": ""
          }
        },
        {
          "name": "Trending (7-day window)",
