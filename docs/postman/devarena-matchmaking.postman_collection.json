              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/leaderboard/friends?period=ALL_TIME&page=1&pageSize=50",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leaderboard",
                "friends"
              ],
              "query": [
                {
                  "key": "period",
                  "value": "ALL_TIME",
                  "description": ""
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": ""
                },
                {
                  "key": "pageSize",
                  "value": "50",
                  "description": ""
                }
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "Ranks you against your accepted friends."
          }
        }
      ]
    },
    {
      "name": "Rating",
      "item": [
        {
          "name": "Rating history + stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rating/history?limit=50",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rating",
                "history"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "50",
                  "description": ""
                }
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "Returns { stats: { current, peak, winStreak, lossStreak, games, wins, losses }, history: [...] }."
          }
        }
      ]
    },
    {
      "name": "Error cases",
      "item": [
        {
          "name": "Duplicate join -> ALREADY_QUEUED",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/join",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "queue",
                "join"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "409 if already queued.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"ONE_VS_ONE\",\n  \"region\": \"GLOBAL\",\n  \"language\": \"javascript\",\n  \"skill\": \"ANY\"\n}"
            }
          }
        },
        {
          "name": "Leave when not queued -> NOT_QUEUED",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/leave",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "queue",
                "leave"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "404."
          }
        },
        {
          "name": "Hammer join -> RATE_LIMITED",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/queue/join",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "queue",
                "join"
              ]
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "description": "429 after >5 joins in the window.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"ONE_VS_ONE\",\n  \"region\": \"GLOBAL\",\n  \"language\": \"javascript\",\n  \"skill\": \"ANY\"\n}"
            }
          }
        }
      ]
    }
  ]
}