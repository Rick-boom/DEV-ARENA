{
  "name": "@devarena/socket-service",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time communication backbone for DevArena: Socket.IO gateway with JWT auth, room/presence managers, and Redis-adapter horizontal scaling.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@devarena/shared-types": "workspace:*",
    "@devarena/shared-utils": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@devarena/eslint-config": "workspace:*",
    "@devarena/ts-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "pino-pretty": "^13.0.0",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
